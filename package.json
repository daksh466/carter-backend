{
  "name": "carter-crm-backend",
  "version": "1.0.0",
  "description": "Express + MongoDB backend for Carter CRM",
  "main": "server.js",
  "scripts": {
"start":"node server.js",
    "dev": "node start-all.js",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "test:all": "npm --prefix backend test -- --silent",
    "perf:guard": "node scripts/performance.load.js",
    "onboarding:smoke": "node scripts/onboarding.smoke.js",
    "deploy:staging": "npx pm2 startOrReload ecosystem.config.js --env staging && node scripts/performance.load.js",
    "deploy:prod": "npm --prefix frontend run build && npx pm2 startOrReload ecosystem.config.js --env production",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:verbose": "jest --verbose --coverage"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.0",
    "pdfkit": "^0.13.0",
    "rate-limiter-flexible": "^10.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2"
  }
}
